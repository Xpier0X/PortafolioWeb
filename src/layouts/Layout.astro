---
import "../styles/global.css"
import Analytics from "@vercel/analytics/astro"
import SpeedInsights from "@vercel/speed-insights/astro"

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = "Portafolio de Piero Leon — Desarrollador Frontend especializado en WordPress, TypeScript y Tailwind CSS. Estudiante de Ingeniería de Sistemas en Lima, Perú.",
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Piero Leon — Portafolio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- SEO -->
    <meta name="author" content="Piero Daniel Leon Yaipen" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f0e8de" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- Preload theme to avoid FOUC -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (saved === "dark" || (!saved && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <slot />

    <Analytics />
    <SpeedInsights />

    <script>
      (function () {
        var html = document.documentElement;

        function setTheme(dark: boolean) {
          if (dark) {
            html.classList.add("dark");
          } else {
            html.classList.remove("dark");
          }
          try {
            localStorage.setItem("theme", dark ? "dark" : "light");
          } catch (_) {}
          var tb = document.getElementById("themeBtn");
          var sl = document.getElementById("stickyModeLabel");
          if (tb) tb.textContent = dark ? "[Claro]" : "[Oscuro]";
          if (sl) sl.textContent = dark ? "Claro" : "Oscuro";
        }

        // Initialize from saved preference or OS preference
        var saved = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        setTheme(saved ? saved === "dark" : prefersDark);

        var btns = [
          document.getElementById("themeBtn"),
          document.getElementById("stickyThemeBtn"),
        ];
        btns.forEach(function (btn) {
          if (!btn) return;
          btn.addEventListener("click", function () {
            setTheme(!html.classList.contains("dark"));
          });
        });

        function scrollToSection(id: string | null) {
          if (!id) return;
          var target = document.querySelector(id);
          if (target)
            target.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        document
          .querySelectorAll('.nav-links a[href^="#"]')
          .forEach(function (a) {
            a.addEventListener("click", function (e) {
              e.preventDefault();
              scrollToSection(a.getAttribute("href"));
            });
          });

        document
          .querySelectorAll('.sticky-links a[href^="#"]')
          .forEach(function (a) {
            a.addEventListener("click", function (e) {
              e.preventDefault();
              scrollToSection(a.getAttribute("href"));
            });
          });

        var stickyNav = document.getElementById("stickyNav");
        var heroEl = document.querySelector(".hero");
        var secEls = document.querySelectorAll(".section[id]");
        var stickyLinks = document.querySelectorAll(".sticky-links a");

        if (!stickyNav || !heroEl) return;

        function updateSticky() {
          if (!heroEl || !stickyNav) return;
          var heroBottom = heroEl.offsetTop + heroEl.offsetHeight - 80;
          stickyNav.classList.toggle("visible", window.scrollY > heroBottom);

          var current = "";
          secEls.forEach(function (s) {
            var rect = s.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.4)
              current = s.getAttribute("id") ?? "";
          });
          stickyLinks.forEach(function (a) {
            a.classList.toggle(
              "active",
              a.getAttribute("href") === "#" + current,
            );
          });
        }

        var ticking = false;
        window.addEventListener("scroll", function () {
          if (!ticking) {
            requestAnimationFrame(function () {
              updateSticky();
              ticking = false;
            });
            ticking = true;
          }
        });
        updateSticky();
      })();
    </script>
  </body>
</html>
