---
import "../styles/global.css"

const { title } = Astro.props
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
  </head>
  <body>
    <slot />

    <script>
      (function () {
        var html = document.documentElement;

        function setTheme(dark) {
          if (dark) {
            html.classList.add("dark");
          } else {
            html.classList.remove("dark");
          }
          try {
            localStorage.setItem("theme", dark ? "dark" : "light");
          } catch (_) {}
          var tb = document.getElementById("themeBtn");
          var sl = document.getElementById("stickyModeLabel");
          if (tb) tb.textContent = dark ? "[Claro]" : "[Oscuro]";
          if (sl) sl.textContent = dark ? "Claro" : "Oscuro";
        }

        setTheme(false);

        var btns = [
          document.getElementById("themeBtn"),
          document.getElementById("stickyThemeBtn"),
        ];
        btns.forEach(function (btn) {
          if (!btn) return;
          btn.addEventListener("click", function () {
            setTheme(!html.classList.contains("dark"));
          });
        });

        function scrollToSection(id) {
          var target = document.querySelector(id);
          if (target)
            target.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        document
          .querySelectorAll('.nav-links a[href^="#"]')
          .forEach(function (a) {
            a.addEventListener("click", function (e) {
              e.preventDefault();
              scrollToSection(a.getAttribute("href"));
            });
          });

        document
          .querySelectorAll('.sticky-links a[href^="#"]')
          .forEach(function (a) {
            a.addEventListener("click", function (e) {
              e.preventDefault();
              scrollToSection(a.getAttribute("href"));
            });
          });

        var stickyNav = document.getElementById("stickyNav");
        var heroEl = document.querySelector(".hero");
        var secEls = document.querySelectorAll(".section[id]");
        var stickyLinks = document.querySelectorAll(".sticky-links a");

        function updateSticky() {
          var heroBottom = heroEl.offsetTop + heroEl.offsetHeight - 80;
          stickyNav.classList.toggle("visible", window.scrollY > heroBottom);

          var current = "";
          secEls.forEach(function (s) {
            var rect = s.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.4)
              current = s.getAttribute("id");
          });
          stickyLinks.forEach(function (a) {
            a.classList.toggle(
              "active",
              a.getAttribute("href") === "#" + current,
            );
          });
        }

        var ticking = false;
        window.addEventListener("scroll", function () {
          if (!ticking) {
            requestAnimationFrame(function () {
              updateSticky();
              ticking = false;
            });
            ticking = true;
          }
        });
        updateSticky();
      })();
    </script>
  </body>
</html>
