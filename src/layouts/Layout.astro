---
import "../styles/global.css"
import Analytics from "@vercel/analytics/astro"
import SpeedInsights from "@vercel/speed-insights/astro"

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = "Portafolio de Piero Leon — Desarrollador Frontend especializado en WordPress, TypeScript y Tailwind CSS. Estudiante de Ingeniería de Sistemas en Lima, Perú.",
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Piero Leon — Portafolio" />
    <meta property="og:image" content={new URL("/og-image.svg", Astro.site)} />
    <meta property="og:image:alt" content="Piero Leon — Desarrollador Frontend" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@Xpier0X" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-image.svg", Astro.site)} />

    <!-- SEO -->
    <meta name="author" content="Piero Daniel Leon Yaipen" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f0e8de" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- Preload theme to avoid FOUC -->
    <script is:inline>
      ;(function () {
        try {
          var saved = localStorage.getItem("theme")
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
          if (saved === "dark" || (!saved && prefersDark)) {
            document.documentElement.classList.add("dark")
          }
        } catch (_) {}
      })()
    </script>
  </head>
  <body>
    <slot />

    <Analytics />
    <SpeedInsights />

    <script>
      ;(function () {
        var html = document.documentElement

        function readTheme(): boolean | null {
          try {
            var saved = localStorage.getItem("theme")
            if (saved === "dark") return true
            if (saved === "light") return false
          } catch (_) {}
          return null
        }

        function setTheme(dark: boolean) {
          if (dark) {
            html.classList.add("dark")
          } else {
            html.classList.remove("dark")
          }
          try {
            localStorage.setItem("theme", dark ? "dark" : "light")
          } catch (_) {}
          var sl = document.getElementById("stickyModeLabel")
          document
            .querySelectorAll<HTMLButtonElement>("[data-theme-toggle]")
            .forEach(function (button) {
              button.textContent = dark ? "[Claro]" : "[Oscuro]"
              button.setAttribute("aria-pressed", String(dark))
              button.setAttribute(
                "aria-label",
                dark ? "Cambiar a tema claro" : "Cambiar a tema oscuro",
              )
            })
          if (sl) sl.textContent = dark ? "Claro" : "Oscuro"
        }

        // Initialize from saved preference or OS preference
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
        setTheme(readTheme() ?? prefersDark)

        document.querySelectorAll("[data-theme-toggle]").forEach(function (button) {
          button.addEventListener("click", function () {
            setTheme(!html.classList.contains("dark"))
          })
        })

        function scrollToSection(id: string | null) {
          if (!id) return
          var target = document.querySelector(id)
          if (target) {
            var reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches
            target.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" })
            history.replaceState(null, "", id)
          }
        }

        document
          .querySelectorAll<HTMLAnchorElement>('[data-scroll-link][href^="#"]')
          .forEach(function (a) {
            a.addEventListener("click", function (e) {
              e.preventDefault()
              scrollToSection(a.getAttribute("href"))
            })
          })

        var stickyNav = document.getElementById("stickyNav")
        var heroEl = document.querySelector<HTMLElement>(".hero")
        var secEls = document.querySelectorAll(".section[id]")
        var stickyLinks = document.querySelectorAll(".sticky-links a")

        if (!stickyNav || !heroEl) return

        function updateSticky() {
          if (!heroEl || !stickyNav) return
          var heroBottom = heroEl.offsetTop + heroEl.offsetHeight - 80
          stickyNav.classList.toggle("visible", window.scrollY > heroBottom)

          var current = ""
          secEls.forEach(function (s) {
            var rect = s.getBoundingClientRect()
            if (rect.top < window.innerHeight * 0.4) current = s.getAttribute("id") ?? ""
          })
          stickyLinks.forEach(function (a) {
            a.classList.toggle("active", a.getAttribute("href") === "#" + current)
            if (a.getAttribute("href") === "#" + current) {
              a.setAttribute("aria-current", "page")
            } else {
              a.removeAttribute("aria-current")
            }
          })
        }

        var ticking = false
        window.addEventListener("scroll", function () {
          if (!ticking) {
            requestAnimationFrame(function () {
              updateSticky()
              ticking = false
            })
            ticking = true
          }
        })
        updateSticky()
      })()
    </script>
  </body>
</html>
