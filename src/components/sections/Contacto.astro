---
import { SITE } from "../../data/site"
---

<section
  id="contacto"
  class="section mb-20 pb-15 border-b-2 border-border max-[480px]:mb-15 max-[480px]:pb-10"
>
  <div
    class="section-head flex justify-between items-baseline mb-10 pb-3 border-b-2 border-border relative"
  >
    <span class="bleed-num max-[860px]:hidden" aria-hidden="true">04</span>
    <h2
      class="font-bold font-body text-[11px] leading-none uppercase tracking-[0.18em] text-fg dark:text-accent"
    >
      Contacto
    </h2>
    <span class="num font-body text-[10px] leading-none text-muted tracking-widest">Disponible</span
    >
  </div>

  <div class="contact">
    <div class="channels flex flex-wrap gap-0">
      <a
        href={`mailto:${SITE.email}`}
        class="flex-2 min-w-55 block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg dark:hover:bg-accent dark:hover:text-bg break-all py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5"
      >
        <span
          class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2"
          >Email</span
        >
        {SITE.email}
      </a>
      <a
        href={SITE.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-2 min-w-55 block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg dark:hover:bg-accent dark:hover:text-bg break-all py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5"
      >
        <span
          class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2"
          >LinkedIn</span
        >
        {SITE.social.linkedin.replace("https://", "")}
      </a>
      <a
        href={SITE.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 min-w-55 block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg dark:hover:bg-accent dark:hover:text-bg break-all py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5"
      >
        <span
          class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2"
          >GitHub</span
        >
        {SITE.social.github.replace("https://", "")}
      </a>
      <a
        href={SITE.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 min-w-55 block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg dark:hover:bg-accent dark:hover:text-bg break-all py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5"
      >
        <span
          class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2"
          >WhatsApp</span
        >
        {SITE.phone}
      </a>
    </div>
  </div>
</section>
