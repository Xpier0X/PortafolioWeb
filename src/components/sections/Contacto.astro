---
import { SITE } from "../../data/site"
---

<section class="section mb-20 pb-[60px] border-b-2 border-border max-[480px]:mb-[60px] max-[480px]:pb-10">
  <div class="section-head flex justify-between items-baseline mb-10 pb-3 border-b-2 border-border relative">
    <span class="bleed-num max-[860px]:hidden">04</span>
    <h2 class="font-bold font-body text-[11px] leading-none uppercase tracking-[0.18em] text-fg">Contacto</h2>
    <span class="num font-body text-[10px] leading-none text-muted tracking-[0.1em]">Disponible</span>
  </div>

  <div class="contact">
    <div class="channels flex flex-wrap gap-0">
      <a href={`mailto:${SITE.email}`}
        class="flex-[2] min-w-[220px] block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg [word-break:break-all] py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5">
        <span class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2">Email</span>
        {SITE.email}
      </a>
      <a href={SITE.social.linkedin} target="_blank" rel="noopener"
        class="flex-1 min-w-[220px] block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg [word-break:break-all] py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5">
        <span class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2">LinkedIn</span>
        {SITE.social.linkedin.replace("https://", "")}
      </a>
      <a href={SITE.social.github} target="_blank" rel="noopener"
        class="flex-1 min-w-[220px] block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg [word-break:break-all] py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5">
        <span class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2">GitHub</span>
        {SITE.social.github.replace("https://", "")}
      </a>
      <a href={`tel:${SITE.phone}`}
        class="flex-1 min-w-[220px] block font-body text-[13px] leading-none text-fg no-underline border-2 border-border transition-[background,color] duration-150 hover:bg-fg hover:text-bg [word-break:break-all] py-6 px-5 -mt-px -ml-px max-[480px]:px-4 max-[480px]:py-5">
        <span class="block font-body text-[10px] leading-none uppercase tracking-[0.15em] text-accent mb-2">Teléfono</span>
        {SITE.phone}
      </a>
    </div>
  </div>
</section>
